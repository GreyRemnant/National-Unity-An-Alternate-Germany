title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.workers = 46; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;
Q.catholics = 30;

Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployed', 'catholics'];
Q.parties = ['spd', 'sapd', 'cdu', 'aspd', 'lvp', 'dkp', 'ndpd', 'other'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.workers_spd = 65;
Q.workers_sapd = 20;
Q.workers_cdu = 5;
Q.workers_aspd = 0;
Q.workers_lvp = 0;
Q.workers_dkp = 5;
Q.workers_ndpd = 0;
Q.workers_other = 10;

Q.old_middle_spd = 5;
Q.old_middle_sapd = 0;
Q.old_middle_cdu = 5;
Q.old_middle_aspd= 10;
Q.old_middle_lvp = 25;
Q.old_middle_dkp = 25;
Q.old_middle_ndpd = 10;
Q.old_middle_other = 10;

Q.new_middle_spd = 5;
Q.new_middle_sapd = 0;
Q.new_middle_cdu = 10;
Q.new_middle_aspd= 25;
Q.new_middle_lvp = 25;
Q.new_middle_dkp = 10;
Q.new_middle_ndpd = 5;
Q.new_middle_other = 15;

Q.rural_spd = 10;
Q.rural_sapd = 0;
Q.rural_cdu = 5;
Q.rural_aspd= 5;
Q.rural_lvp = 15;
Q.rural_dkp = 45;
Q.rural_ndpd = 5;
Q.rural_other = 10;

Q.unemployed_spd = 25;
Q.unemployed_sapd = 55;
Q.unemployed_cdu = 1;
Q.unemployed_aspd = 0;
Q.unemployed_lvp = 0;
Q.unemployed_dkp = 5;
Q.unemployed_ndpd = 15;
Q.unemployed_other = 9;

Q.catholics_spd = 15;
Q.catholics_sapd = 5;
Q.catholics_cdu = 50;
Q.catholics_aspd = 0;
Q.catholics_lvp = 5;
Q.catholics_dkp = 5;
Q.catholics_ndpd = 0;
Q.catholics_other = 10;
!}
go-to: election_algorithm
set-jump: post_election

